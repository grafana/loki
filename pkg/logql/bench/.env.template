# Copy this file to .env and fill in real values.
# .env is git-ignored and will be sourced automatically by `make discover`.

# Loki API credentials
LOKI_ADDR=https://your-loki-endpoint
LOKI_USERNAME=your-username
LOKI_PASSWORD=your-password

# S3 storage credentials for TSDB index access
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 bucket configuration
S3_BUCKET=your-bucket-name
S3_REGION=your-region
S3_ENDPOINT=s3.dualstack.your-region.amazonaws.com
TABLE_PREFIX=your_index_table_prefix_

# Discover configuration
DISCOVER_SELECTOR=namespace=~"namespace-1|namespace-2|namespace-3"
# Optional: override the discovery time window (RFC3339).
# Defaults to the last 24h. Set these to target a specific range,
# DISCOVER_FROM=2026-03-09T00:00:00Z
# DISCOVER_TO=2026-03-10T00:00:00Z

# Remote correctness test — two Loki endpoints to compare
# NOTE: if one endpoint has a data freshness lag, set DISCOVER_FROM/DISCOVER_TO
# above so the discovered time range falls within both endpoints' valid windows.
REMOTE_ADDR_1=http://baseline-loki-endpoint:3100
REMOTE_ADDR_2=http://test-loki-endpoint:3101
REMOTE_ORG_ID=your-tenant-id
REMOTE_TIMEOUT=30m
