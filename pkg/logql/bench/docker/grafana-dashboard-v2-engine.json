    {
      "title": "V2 Subquery QPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(loki_engine_v2_subqueries_total[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Query Execution Latency (p50 / p99)",
