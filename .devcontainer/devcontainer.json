{
  "build": {
    "dockerfile": "../loki-build-image/Dockerfile",
    "context": "..",
    "args": {
      "GO_VERSION": "1.26.3",
      "INSTALL_WORKFLOW_DEPS_ARGS": "dist lint loki-release loki-build-tools"
    }
  },
  "containerEnv": {
    "BUILD_IN_CONTAINER": "false"
  },
  "customizations": {
    "vscode": {
      "settings": {},
      "extensions": ["golang.go", "Grafana.vscode-jsonnet"]
    }
  },
  "features": {}
}
