      <rule pattern="[([]"><token type="Comment"/><push/></rule>
      <rule pattern="[)\]]"><token type="Comment"/><pop depth="1"/></rule>
      <rule pattern="[^()[\]]+"><token type="Comment"/></rule>
    </state>
    <state name="commented-datum">
      <rule pattern="(?x).*?
      (?=
        \s         # whitespace
        | ;        # comment
        | \#[;|!] # fancy comments
        | [)\]]    # end delimiters
        | $        # end of file
      )
    "><token type="Comment"/><pop depth="1"/></rule>
    </state>
  </rules>
</lexer>

